SMART_FRIDGE_DATABASE_URL=sqlite:///./data/smart_fridge.db
SMART_FRIDGE_SCAN_STORAGE=./data/scans
SMART_FRIDGE_UPLOADS_STORAGE=./data/uploads

SMART_FRIDGE_LOG_LEVEL=INFO
SMART_FRIDGE_JSON_LOGS=false
SMART_FRIDGE_SCHEDULER_ENABLED=true

SMART_FRIDGE_HOST=0.0.0.0
SMART_FRIDGE_PORT=8765
SMART_FRIDGE_RELOAD=false

# Auto dev HTTPS (default true): creates data/certs/dev.pem + dev.key via openssl
SMART_FRIDGE_DEV_HTTPS=true

# Override with your own PEM files (optional)
SMART_FRIDGE_SSL_CERTFILE=
SMART_FRIDGE_SSL_KEYFILE=

SMART_FRIDGE_TELEGRAM_BOT_TOKEN=
SMART_FRIDGE_TELEGRAM_CHAT_ID=
SMART_FRIDGE_TELEGRAM_POLL_SECONDS=30

SMART_FRIDGE_VLM_ENABLED=false
SMART_FRIDGE_VLM_ENDPOINT=http://127.0.0.1:1234/v1/chat/completions
SMART_FRIDGE_VLM_CONFIDENCE_BELOW=0.50
SMART_FRIDGE_VLM_LOG_PREVIEW_CHARS=4000
