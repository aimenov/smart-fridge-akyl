# Copy to `.env` (gitignored). Never commit secrets.

# SMART_FRIDGE_DATABASE_URL=sqlite:///./data/smart_fridge.db

# National Catalog gateway — API key from https://nationalcatalog.kz/personal-account/api-keys
# Docs: https://nationalcatalog.kz/gwp/docs  ·  OpenAPI JSON: /gwp/portal/v3/api-docs/portal
# SMART_FRIDGE_NATIONAL_CATALOG_API_KEY=
# Defaults are correct for portal v2 product lookup (override only if needed):
# SMART_FRIDGE_NATIONAL_CATALOG_BASE_URL=https://nationalcatalog.kz/gwp
# SMART_FRIDGE_NATIONAL_CATALOG_GTIN_URL_TEMPLATE={base}/portal/api/v2/products/{tin}
# SMART_FRIDGE_NATIONAL_CATALOG_AUTH_SCHEME=api_key
# SMART_FRIDGE_NATIONAL_CATALOG_AUTH_HEADER=X-API-KEY

# ОФД bulk export (Postman: https://documenter.getpostman.com/view/21459402/2sB2cVe1oW ) — optional overrides
# SMART_FRIDGE_OFD_CATALOG_EXPORT_URL=https://nct.gov.kz/api/integration/ofd/ofd
# SMART_FRIDGE_OFD_IMPORT_DEFAULT_SINCE_DAYS=7

# Logs: full detail in file, quiet console (scan summaries still print via smart_fridge.summary).
# SMART_FRIDGE_LOG_FILE=./data/logs/smart-fridge.log
# SMART_FRIDGE_CONSOLE_LOG_LEVEL=WARNING
